{
  "name": "ai-middleware-challenge",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "dev": "npm run dev:all",
    "build": "npm run build:web",
    "dev:all": "node scripts/dev.mjs",
    "test:api": "cd apps/api && python -m unittest discover -s tests -v"
  }
}
